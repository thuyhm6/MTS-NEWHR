    <!-- Check if employee exists and is active by PERSON_ID -->
    <select id="existsAndActiveByPersonId" resultType="boolean">
        SELECT CASE WHEN COUNT(*) > 0 THEN 1 ELSE 0 END
        FROM hr_employee 
        WHERE PERSON_ID = #{personId}
          AND ACTIVITY = 1
    </select>

    <!-- Check if employee exists by EMPID -->
    <select id="existsByEmpId" resultType="boolean">
