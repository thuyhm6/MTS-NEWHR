    <!-- Thống kê nhân viên theo từng tháng trong năm được chỉ định -->
    <resultMap id="EmpMonthlyStatsResultMap" type="com.ait.hrm.empinfo.dto.EmpMonthlyStatsDto">
        <result column="MONTH_NUM"        property="monthNum"/>
        <result column="EMP_COUNT"        property="empCount"/>
        <result column="NEW_JOINER_COUNT" property="newJoinerCount"/>
        <result column="LEAVER_COUNT"     property="leaverCount"/>
    </resultMap>

    <select id="selectEmpMonthlyStats" resultMap="EmpMonthlyStatsResultMap">
        SELECT
            m.MONTH_NUM,
            (
                SELECT COUNT(*)
                FROM hr_employee e
                WHERE e.CPNY_ID = #{cpnyId, jdbcType=VARCHAR}
                  AND TRUNC(e.DATE_STARTED) &lt;= m.MONTH_END
                  AND (e.DATE_LEFT IS NULL OR TRUNC(e.DATE_LEFT) &gt; m.MONTH_END)
            ) AS EMP_COUNT,
            (
                SELECT COUNT(*)
                FROM hr_employee n
                WHERE n.CPNY_ID = #{cpnyId, jdbcType=VARCHAR}
                  AND TRUNC(n.DATE_STARTED) &gt;= m.MONTH_START
                  AND TRUNC(n.DATE_STARTED) &lt;= m.MONTH_END
            ) AS NEW_JOINER_COUNT,
            (
                SELECT COUNT(*)
                FROM hr_employee lv
                WHERE lv.CPNY_ID = #{cpnyId, jdbcType=VARCHAR}
                  AND lv.DATE_LEFT IS NOT NULL
                  AND TRUNC(lv.DATE_LEFT) &gt;= m.MONTH_START
                  AND TRUNC(lv.DATE_LEFT) &lt;= m.MONTH_END
            ) AS LEAVER_COUNT
        FROM (
            SELECT
                LEVEL AS MONTH_NUM,
                TRUNC(ADD_MONTHS(TO_DATE(TO_CHAR(#{year, jdbcType=INTEGER}) || '-01-01', 'YYYY-MM-DD'), LEVEL - 1), 'MM') AS MONTH_START,
                LAST_DAY(ADD_MONTHS(TO_DATE(TO_CHAR(#{year, jdbcType=INTEGER}) || '-01-01', 'YYYY-MM-DD'), LEVEL - 1))    AS MONTH_END
            FROM DUAL
            CONNECT BY LEVEL &lt;= 12
        ) m
        ORDER BY m.MONTH_NUM
    </select>

    <!-- Get employee statistics by department -->
    <select id="getEmployeeStatsByDept" resultType="java.util.Map">
        SELECT 
            DEPTNO as deptNo,
            COUNT(*) as totalEmployees,
            SUM(CASE WHEN ACTIVITY = 1 THEN 1 ELSE 0 END) as activeEmployees,
            SUM(CASE WHEN IS_PROBATION = 'Y' THEN 1 ELSE 0 END) as probationEmployees
        FROM hr_employee 
        WHERE DEPTNO IS NOT NULL
        GROUP BY DEPTNO
        ORDER BY DEPTNO
    </select>

