        SELECT DISTINCT FINAL_DEGREE_CODE 
        FROM hr_personal_info 
        WHERE ACTIVITY = 1 AND FINAL_DEGREE_CODE IS NOT NULL
        ORDER BY FINAL_DEGREE_CODE
    </select>

    <!-- Get personal info statistics -->
    <select id="getPersonalInfoStats" resultType="java.util.Map">
        SELECT 
            COUNT(*) as totalRecords,
            SUM(CASE WHEN ACTIVITY = 1 THEN 1 ELSE 0 END) as activeRecords,
            SUM(CASE WHEN SEXCODE = 'M' THEN 1 ELSE 0 END) as maleCount,
            SUM(CASE WHEN SEXCODE = 'F' THEN 1 ELSE 0 END) as femaleCount,
            SUM(CASE WHEN MARITAL_STATUS_CODE = 'S' THEN 1 ELSE 0 END) as singleCount,
            SUM(CASE WHEN MARITAL_STATUS_CODE = 'M' THEN 1 ELSE 0 END) as marriedCount
        FROM hr_personal_info
    </select>

