    <!-- Delete personal info -->
    <delete id="deleteByPersonId">
        DELETE FROM hr_personal_info 
        WHERE PERSON_ID = #{personId}
    </delete>

    <!-- ============================================ -->
    <!-- UTILITY QUERIES -->
    <!-- ============================================ -->

    <!-- Check if personal info exists and is active by PERSON_ID -->
    <select id="existsAndActiveByPersonId" resultType="boolean">
        SELECT CASE WHEN COUNT(*) > 0 THEN 1 ELSE 0 END
        FROM hr_personal_info 
        WHERE PERSON_ID = #{personId}
          AND ACTIVITY = 1
    </select>

    <!-- Check if personal info exists by PERSON_ID -->
    <select id="existsByPersonId" resultType="boolean">
        SELECT CASE WHEN COUNT(*) > 0 THEN 1 ELSE 0 END
        FROM hr_personal_info 
        WHERE PERSON_ID = #{personId}
    </select>

    <!-- Check if ID card number exists -->
    <select id="existsByIdcardNo" resultType="boolean">
        SELECT CASE WHEN COUNT(*) > 0 THEN 1 ELSE 0 END
        FROM hr_personal_info 
        WHERE IDCARD_NO = #{idcardNo}
          AND ACTIVITY = 1
    </select>

    <!-- Check if email exists -->
    <select id="existsByEmail" resultType="boolean">
        SELECT CASE WHEN COUNT(*) > 0 THEN 1 ELSE 0 END
        FROM hr_personal_info 
        WHERE EMAIL = #{email}
          AND ACTIVITY = 1
    </select>

    <!-- Get distinct sex codes -->
    <select id="getDistinctSexCodes" resultType="String">
        SELECT DISTINCT SEXCODE 
        FROM hr_personal_info 
        WHERE ACTIVITY = 1 AND SEXCODE IS NOT NULL
        ORDER BY SEXCODE
    </select>

    <!-- Get distinct marital status codes -->
    <select id="getDistinctMaritalStatusCodes" resultType="String">
        SELECT DISTINCT MARITAL_STATUS_CODE 
        FROM hr_personal_info 
        WHERE ACTIVITY = 1 AND MARITAL_STATUS_CODE IS NOT NULL
        ORDER BY MARITAL_STATUS_CODE
    </select>

    <!-- Get distinct nation codes -->
    <select id="getDistinctNationCodes" resultType="String">
        SELECT DISTINCT NATION_CODE 
        FROM hr_personal_info 
        WHERE ACTIVITY = 1 AND NATION_CODE IS NOT NULL
        ORDER BY NATION_CODE
    </select>

    <!-- Get distinct nationality codes -->
