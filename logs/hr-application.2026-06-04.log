UPERVISOR_INFO ASI WHERE ASI.DEPTNO = D.DEPTNO AND ASI.PERSON_ID = '11111111' ) AND H.EMP_OFFICE = '15119' AND INSTR(',' || 'D11EV100,D11EV110,D11EV120,D11EV130,D11EV140,D11EV150' || ',', ',' || H.DEPTNO || ',') > 0 ) GROUP BY SORT_NO, AGE_GRP ORDER BY SORT_NO
