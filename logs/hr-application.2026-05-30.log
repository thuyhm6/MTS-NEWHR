(T.WUXIN_JIA, 0)) AS WUXIN_JIA FROM AR_EMP_DAY_TOTAL T JOIN HR_EMPLOYEE HE ON HE.PERSON_ID = T.PERSON_ID AND HE.CPNY_ID = 'HTSV' WHERE T.CPNY_ID = 'HTSV' AND T.DATE_STR >= '2026/04/25' AND T.DATE_STR <= '2026/05/24' GROUP BY HE.PERSON_ID, HE.EMPID, HE.LOCAL_NAME, HE.DEPTNO, HE.POST_GRADE_NO, HE.EMP_TYPE_CODE ORDER BY HE.EMPID
