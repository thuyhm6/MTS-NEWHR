D.DEPTNO AND ASI.PERSON_ID = '11111111' ) AND TRUNC(H.DATE_STARTED) <= TO_DATE('2020/07/01', 'YYYY/MM/DD') AND (H.DATE_LEFT IS NULL OR TRUNC(H.DATE_LEFT) >= TO_DATE('2020/07/01', 'YYYY/MM/DD')) ) GROUP BY SORT_NO, AGE_GRP ORDER BY SORT_NO
